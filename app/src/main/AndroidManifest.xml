<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 权限声明 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- 最低支持 API 31 (Android 12) -->
    <uses-sdk
        android:minSdkVersion="31"
        android:targetSdkVersion="34" />

    <!-- 解析 MediaSession 来源应用的显示名称（Android 11+ 包可见性） -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GlassMusicWidget.Transparent"
        tools:targetApi="31">

        <!-- 主Activity - 设置界面 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.GlassMusicWidget.Main">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 音乐小部件提供者 4x2 -->
        <receiver
            android:name=".MusicWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.glassmusic.widget.ACTION_PLAY_PAUSE" />
                <action android:name="com.glassmusic.widget.ACTION_NEXT" />
                <action android:name="com.glassmusic.widget.ACTION_PREVIOUS" />
                <action android:name="com.glassmusic.widget.ACTION_UPDATE_WIDGET" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/music_widget_info" />
        </receiver>

        <!-- 音乐小部件提供者 4x1 -->
        <receiver
            android:name=".MusicWidgetProvider4x1"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.glassmusic.widget.ACTION_PLAY_PAUSE" />
                <action android:name="com.glassmusic.widget.ACTION_NEXT" />
                <action android:name="com.glassmusic.widget.ACTION_PREVIOUS" />
                <action android:name="com.glassmusic.widget.ACTION_UPDATE_WIDGET" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/music_widget_info_4x1" />
        </receiver>

        <!-- 音乐监听服务 - 继承自NotificationListenerService -->
        <service
            android:name=".MusicMonitorService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>

</manifest>
