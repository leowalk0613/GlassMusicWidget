<?xml version="1.0" encoding="utf-8"?>
<!-- 数据提取规则 -->
<data-extraction-rules>
    <cloud-backup>
        <!-- 备份所有数据 -->
        <include domain="sharedpref" path="."/>
        <include domain="database" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="."/>
        <include domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>
